---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";

const subjects = [
  {
    name: "Maths",
    slug: "maths",
    colorClass: "subject-maths",
    available: true,
    units: [
      {
        code: "UL1MA001",
        colorClass: "ue-m1",
        available: true,
        cours: true,
        exos: false,
      },
      {
        code: "UL1MA002",
        colorClass: "ue-m2",
        available: true,
        cours: false,
        exos: false,
      },
      {
        code: "UL1MA003",
        colorClass: "ue-m3",
        available: false,
        cours: false,
        exos: false,
      },
    ],
  },
  {
    name: "Physique",
    slug: "physique",
    colorClass: "subject-physique",
    available: false,
    units: [],
  },
  {
    name: "Mécanique",
    slug: "meca",
    colorClass: "subject-meca",
    available: false,
    units: [],
  },
];
---




<BaseLayout>
  <canvas id="bg-canvas"></canvas>

<header>
  <div class="header-inner">
    <a class="logo" href={import.meta.env.BASE_URL}>LLab</a>
  </div>
</header>

  <main>
    <section class="hero" id="hero">
      <h1>?</h1>
      <p>?</p>
    </section>

    <div id="disclaimer" class="floating-disclaimer">
      <button id="close-disclaimer" class="close-btn">&times;</button>
      <div class="disclaimer-badge">BÉTA</div>
      <div class="disclaimer-content">
        <p>
          <strong>Site en béta, pour l'instant c'est juste un projet pour cette année.</strong> 
          Ce site est codé sur mon temps libre.
          C'est un bonus pour réviser, N'hésitez pas à faire des retours, il peut (et il y a surement des erreurs) la mécanique arrive bientôt !
        </p>
      </div>
    </div>

<button id="show-disclaimer" class="reopen-btn" style="display: none;">⚠️</button>

    <section class="section">
      <div class="subjects-grid" id="subjects-grid">
        {
          subjects.map((subject, i) => (
            <article
              class={`subject-card ${subject.colorClass} ${
                subject.available ? "is-available" : "is-disabled"
              }`}
              style={`animation-delay: ${i * 0.07}s`}
            >
              <div class="subject-card-content">
                <h2>{subject.name}</h2>
                <div class="subject-card-action">
                  {subject.available ? (
                    <button class="subject-link" data-target={subject.slug}>
                      Accéder
                    </button>
                  ) : (
                    <span class="subject-badge">Indisponible</span>
                  )}
                </div>
              </div>
            </article>
          ))
        }
      </div>

      {
        subjects
          .filter((s) => s.available)
          .map((subject) => (
            <div class="units-view" id={`units-${subject.slug}`}>
              <button class="bouton-retour" data-back aria-label="Retour">
                <svg width="16" height="16" viewBox="0 0 20 20" fill="none">
                  <path
                    d="M13 4L7 10L13 16"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
                Retour
              </button>

              <div class="units-grid">
                {subject.units.map((unit, i) => (
                  <article
                    class={`subject-card ue-card ${unit.colorClass} ${
                      unit.available ? "" : "is-disabled"
                    }`}
                    style={`animation-delay: ${i * 0.08}s`}
                  >
                    <div class="subject-card-content">
                      <h2>{unit.code}</h2>
                      <div class="ue-actions">
                        {unit.cours ? (
                          <a
                            class="ue-btn ue-btn-fill"
                            href={`${import.meta.env.BASE_URL}${subject.slug}/${unit.code.toLowerCase()}/cours/chapitre1`}
                          >
                            Cours
                          </a>
                        ) : (
                          <span class="ue-btn ue-btn-off">Cours</span>
                        )}
                        {unit.exos ? (
                          <a
                            class="ue-btn ue-btn-fill"
                            href={`${import.meta.env.BASE_URL}${subject.slug}/${unit.code.toLowerCase()}/exercices`}
                          >
                            Exercices
                          </a>
                        ) : (
                          <span class="ue-btn ue-btn-off">Exercices</span>
                        )}
                      </div>
                    </div>
                  </article>
                ))}
              </div>
            </div>
          ))
      }
    </section>

    
  </main>



  <Footer />
</BaseLayout>



<script>
  const grid = document.getElementById("subjects-grid");
  const hero = document.getElementById("hero");
  const allUnits = document.querySelectorAll(".units-view");

  function showSubjects() {
    allUnits.forEach((u) => u.classList.remove("units-visible"));
    setTimeout(() => {
      if (grid) {
        grid.style.display = "";
        requestAnimationFrame(() => grid.classList.remove("grid-hidden"));
      }
      if (hero) hero.classList.remove("hero-hidden");
    }, 220);
  }

  function showUnits(slug: string) {
    if (grid) grid.classList.add("grid-hidden");
    if (hero) hero.classList.add("hero-hidden");
    setTimeout(() => {
      if (grid) grid.style.display = "none";
      const panel = document.getElementById(`units-${slug}`);
      if (panel) panel.classList.add("units-visible");
    }, 260);
  }

  document
    .querySelectorAll<HTMLButtonElement>("button[data-target]")
    .forEach((btn) => {
      btn.addEventListener("click", () => {
        const slug = btn.dataset.target;
        if (slug) showUnits(slug);
      });
    });

  document
    .querySelectorAll<HTMLButtonElement>("button[data-back]")
    .forEach((btn) => {
      btn.addEventListener("click", showSubjects);
    });

  const canvas = document.getElementById("bg-canvas") as HTMLCanvasElement;
  if (canvas) {
    const ctx = canvas.getContext("2d")!;
    let w = 0,
      h = 0;

    const COLORS = [
      { r: 255, g: 92, b: 97 }, // maths en rouge
      { r: 139, g: 92, b: 246 }, // physique en violet
      { r: 79, g: 124, b: 255 }, // meca eb bleu
    ];

    interface Particle {
      x: number;
      y: number;
      vx: number;
      vy: number;
      r: number;
      ci: number;
    }
    const particles: Particle[] = [];
    const P_COUNT = 65;
    const MAX_DIST = 120;
    const REPULSE = 35;
    const MAX_SPD = 1.0;


    interface Symbol {
      x: number;
      y: number;
      vx: number;
      vy: number;
      char: string;
      size: number;
      alpha: number;
      ci: number;
      rot: number;
      vrot: number;
    }
    const symbols: Symbol[] = [];
    const S_COUNT = 14;
    const CHARS = [
      "∫",
      "∑",
      "Δ",
      "π",
      "∂",
      "∞",
      "√",
      "λ",
      "θ",
      "φ",
      "∇",
      "ε",
      "ω",
      "μ",
    ];

    interface Orb {
      x: number;
      y: number;
      vx: number;
      vy: number;
      radius: number;
      ci: number;
    }
    const orbs: Orb[] = [];
    const O_COUNT = 3;

    let mouse = { x: -9999, y: -9999 };

    function resize() {
      w = canvas.width = window.innerWidth;
      h = canvas.height = window.innerHeight;
    }

    function init() {
      resize();
      particles.length = 0;
      symbols.length = 0;
      orbs.length = 0;

      for (let i = 0; i < P_COUNT; i++) {
        particles.push({
          x: Math.random() * w,
          y: Math.random() * h,
          vx: (Math.random() - 0.5) * 0.4,
          vy: (Math.random() - 0.5) * 0.4,
          r: Math.random() * 1.3 + 0.4,
          ci: Math.floor(Math.random() * 3),
        });
      }

      for (let i = 0; i < S_COUNT; i++) {
        symbols.push({
          x: Math.random() * w,
          y: Math.random() * h,
          vx: (Math.random() - 0.5) * 0.15,
          vy: (Math.random() - 0.5) * 0.15,
          char: CHARS[i % CHARS.length],
          size: Math.random() * 16 + 12,
          alpha: Math.random() * 0.04 + 0.02,
          ci: Math.floor(Math.random() * 3),
          rot: Math.random() * Math.PI * 2,
          vrot: (Math.random() - 0.5) * 0.003,
        });
      }

      for (let i = 0; i < O_COUNT; i++) {
        orbs.push({
          x: Math.random() * w,
          y: Math.random() * h,
          vx: (Math.random() - 0.5) * 0.12,
          vy: (Math.random() - 0.5) * 0.12,
          radius: Math.random() * 200 + 150,
          ci: i % 3,
        });
      }
    }

    function draw() {
      ctx.clearRect(0, 0, w, h);

      for (const orb of orbs) {
        orb.x += orb.vx;
        orb.y += orb.vy;
        if (orb.x < -orb.radius) orb.x = w + orb.radius;
        if (orb.x > w + orb.radius) orb.x = -orb.radius;
        if (orb.y < -orb.radius) orb.y = h + orb.radius;
        if (orb.y > h + orb.radius) orb.y = -orb.radius;

        const c = COLORS[orb.ci];
        const grad = ctx.createRadialGradient(
          orb.x,
          orb.y,
          0,
          orb.x,
          orb.y,
          orb.radius,
        );
        grad.addColorStop(0, `rgba(${c.r}, ${c.g}, ${c.b}, 0.04)`);
        grad.addColorStop(1, `rgba(${c.r}, ${c.g}, ${c.b}, 0)`);
        ctx.beginPath();
        ctx.arc(orb.x, orb.y, orb.radius, 0, Math.PI * 2);
        ctx.fillStyle = grad;
        ctx.fill();
      }

      for (const s of symbols) {
        s.x += s.vx;
        s.y += s.vy;
        s.rot += s.vrot;
        if (s.x < -40) s.x = w + 40;
        if (s.x > w + 40) s.x = -40;
        if (s.y < -40) s.y = h + 40;
        if (s.y > h + 40) s.y = -40;

        const c = COLORS[s.ci];
        ctx.save();
        ctx.translate(s.x, s.y);
        ctx.rotate(s.rot);
        ctx.font = `${s.size}px "Inter", sans-serif`;
        ctx.textAlign = "center";
        ctx.textBaseline = "middle";
        ctx.fillStyle = `rgba(${c.r}, ${c.g}, ${c.b}, ${s.alpha})`;
        ctx.fillText(s.char, 0, 0);
        ctx.restore();
      }

      for (let i = 0; i < particles.length; i++) {
        const p = particles[i];

        const dx = mouse.x - p.x;
        const dy = mouse.y - p.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 220 && dist > 1) {
          p.vx += (dx / dist) * 0.004;
          p.vy += (dy / dist) * 0.004;
        }

        for (let j = i + 1; j < particles.length; j++) {
          const p2 = particles[j];
          const rx = p.x - p2.x;
          const ry = p.y - p2.y;
          const rd = Math.sqrt(rx * rx + ry * ry);

          if (rd < REPULSE && rd > 0.1) {
            const force = (1 - rd / REPULSE) * 0.025;
            const nx = rx / rd;
            const ny = ry / rd;
            p.vx += nx * force;
            p.vy += ny * force;
            p2.vx -= nx * force;
            p2.vy -= ny * force;
          }

          if (rd < MAX_DIST) {
            const alpha = (1 - rd / MAX_DIST) * 0.055;
            const c = COLORS[p.ci];
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(p2.x, p2.y);
            ctx.strokeStyle = `rgba(${c.r}, ${c.g}, ${c.b}, ${alpha})`;
            ctx.lineWidth = 0.4;
            ctx.stroke();
          }
        }

        p.vx *= 0.993;
        p.vy *= 0.993;
        const speed = Math.sqrt(p.vx * p.vx + p.vy * p.vy);
        if (speed > MAX_SPD) {
          p.vx = (p.vx / speed) * MAX_SPD;
          p.vy = (p.vy / speed) * MAX_SPD;
        }

        p.x += p.vx;
        p.y += p.vy;
        if (p.x < -20) p.x = w + 20;
        if (p.x > w + 20) p.x = -20;
        if (p.y < -20) p.y = h + 20;
        if (p.y > h + 20) p.y = -20;

        const c = COLORS[p.ci];
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${c.r}, ${c.g}, ${c.b}, 0.18)`;
        ctx.fill();
      }

      requestAnimationFrame(draw);
    }

    window.addEventListener("resize", resize);
    window.addEventListener("mousemove", (e) => {
      mouse.x = e.clientX;
      mouse.y = e.clientY;
    });
    window.addEventListener("mouseleave", () => {
      mouse.x = -9999;
      mouse.y = -9999;
    });

    init();
    draw();
  }




  const disclaimer = document.getElementById('disclaimer');
  const closeBtn = document.getElementById('close-disclaimer');
  const reopenBtn = document.getElementById('show-disclaimer');

  function hideDisclaimer() {
    disclaimer.classList.add('hidden');
    setTimeout(() => {
      reopenBtn.style.display = 'flex';
    }, 400);
  }

  function showDisclaimer() {
    reopenBtn.style.display = 'none';
    disclaimer.classList.remove('hidden');
  }

  closeBtn.addEventListener('click', hideDisclaimer);
  reopenBtn.addEventListener('click', showDisclaimer);

  setTimeout(hideDisclaimer, 10000);
</script>
